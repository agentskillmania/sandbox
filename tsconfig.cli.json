{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/cli",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["src/cli/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
