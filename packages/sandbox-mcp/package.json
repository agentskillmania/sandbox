{
  "name": "@agentskillmania/sandbox-mcp",
  "version": "0.1.0",
  "description": "MCP server for @agentskillmania/sandbox - Execute code in WASM sandbox",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sandbox-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:unit": "vitest run test/unit",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run test:unit && npm run build"
  },
  "dependencies": {
    "@agentskillmania/sandbox": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sandbox",
    "wasm",
    "code-execution"
  ],
  "author": {
    "name": "yusangeng",
    "email": "yusangeng@outlook.com"
  },
  "license": "MIT"
}
