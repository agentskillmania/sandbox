{
  "name": "@agentskillmania/sandbox",
  "version": "0.1.0",
  "private": false,
  "description": "WASM sandbox for busybox and micropython",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "exec-in-sandbox": "./bin/exec-in-sandbox.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:cli",
    "build:lib": "vite build",
    "build:cli": "node scripts/build-cli.cjs",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "postinstall": "node scripts/install-runtime.cjs",
    "prepublishOnly": "npm run test:unit && npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "wasm",
    "wasi",
    "wasmtime",
    "busybox",
    "micropython",
    "sandbox",
    "webassembly"
  ],
  "author": {
    "name": "yusangeng",
    "email": "yusangeng@outlook.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentskillmania/sandbox.git"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@agentskillmania/settings-yaml": "^0.1.0",
    "adm-zip": "^0.5.10",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "mkdirp": "^3.0.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.50.0",
    "husky": "^9.1.7",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "files": [
    "dist",
    "bin",
    "scripts",
    "wasm",
    "README.md",
    "LICENSE"
  ]
}
