{
  "name": "@agentskillmania/sandbox-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "WASM sandbox tool with MCP server support",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "test": "pnpm -r --filter './packages/*' run test",
    "test:unit": "pnpm -r --filter './packages/*' run test:unit",
    "test:integration": "pnpm -r --filter './packages/*' run test:integration",
    "lint": "eslint 'packages/*/src/**/*.{ts,js}'",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.50.0",
    "husky": "^9.1.7",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=8.0.0"
  }
}
